# ── Venom Router — environment configuration ─────────────────────────────────
# Copy this file to `.env` and fill in the values. Never commit real secrets.
# `.env` is gitignored; this `.env.example` is the canonical list of required vars.

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────
# Project URL, e.g. https://<ref>.supabase.co
SUPABASE_URL=

# Server-only key that bypasses RLS. Found in: Supabase Dashboard → Project
# Settings → API → service_role secret. NEVER expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Anon/publishable key (RLS-enforced). Safe for the browser.
SUPABASE_PUBLISHABLE_KEY=

# Vite-prefixed copies of the publishable values — injected into client code at
# build time (only VITE_* vars reach the browser bundle).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: Supabase project reference id (metadata only; not required to run).
SUPABASE_PROJECT_ID=
VITE_SUPABASE_PROJECT_ID=

# ── Encryption (REQUIRED) ────────────────────────────────────────────────────
# AES-256-GCM key for encrypting provider credentials at rest. MUST be set —
# the app refuses to start without it (there is no insecure fallback).
# Generate one with:  openssl rand -hex 32
VENOM_ENCRYPTION_KEY=

# ── Optional: operational ────────────────────────────────────────────────────
# Shared secret required by the internal /api/internal/run-workers trigger
# (Cloudflare cron or a manual curl). If unset, the endpoint rejects all calls.
DEV_WORKER_SECRET=

# Structured-logger verbosity: debug | info | warn | error (default: info).
# A Vite-prefixed copy lets you tune client-side logging independently.
LOG_LEVEL=info
VITE_LOG_LEVEL=info

# ── Optional: test fixtures (scripts/* only) ─────────────────────────────────
# Used by scripts/fetch-live-models.ts to exercise the Antigravity adapter.
ANTIGRAVITY_TEST_PROJECT=
ANTIGRAVITY_TEST_TOKEN=
